# Pathfinder env template — copy to .env and fill in
DATABASE_URL="file:./prisma/dev.db"

# NextAuth — generate a real secret with `openssl rand -base64 32`
AUTH_SECRET="change-me-in-production-pls"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: AI assistant — leave unset to disable the feature gracefully.
# ANTHROPIC_API_KEY=

# Object storage (DO Spaces / any S3-compatible). When set, background
# image uploads go directly to Spaces via a pre-signed PUT URL. When
# unset, uploads fall back to the FloorAsset table in the DB.
# DO_SPACES_REGION=fra1
# DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
# DO_SPACES_BUCKET=
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# NEXT_PUBLIC_DO_SPACES_BUCKET=
# NEXT_PUBLIC_DO_SPACES_ENDPOINT=
# NEXT_PUBLIC_DO_SPACES_FOLDER=pathfinder
