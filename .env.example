# Pathfinder env template — copy to .env and fill in
DATABASE_URL="file:./prisma/dev.db"

# NextAuth — generate a real secret with `openssl rand -base64 32`
AUTH_SECRET="change-me-in-production-pls"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: AI assistant — leave unset to disable the feature gracefully.
# ANTHROPIC_API_KEY=
