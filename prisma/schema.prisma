// Pathfinder DB schema.
// Multi-tenant: every Building belongs to a User. Floor *geometry* lives in
// the `data` field as a JSON-encoded FloorMap (see src/lib/map/schema.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------- NextAuth tables ----------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  buildings Building[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------- Domain ----------------

model Building {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug        String   @unique
  nameEn      String
  nameEl      String
  description String?

  // Publishing
  status      String   @default("draft") // "draft" | "published"
  publicSlug  String?  @unique
  publishedAt DateTime?

  floors    Floor[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  slug       String
  level      Int
  nameEn     String
  nameEl     String
  /// JSON-encoded FloorMap (see src/lib/map/schema.ts).
  data       String
  assets     FloorAsset[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([buildingId, slug])
}

/// Bytes-on-disk for floor assets that are too big to live inside the
/// FloorMap JSON — currently just background tracing images. Served via
/// GET /api/assets/[id]. Drop-in replacement when we move to S3/Spaces:
/// only the upload route needs to change.
model FloorAsset {
  id        String   @id @default(cuid())
  floorId   String
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  mimeType  String
  bytes     Bytes
  createdAt DateTime @default(now())
}
