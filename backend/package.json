{
  "name": "pathfinder",
  "version": "1.0.0",
  "description": "Pathfinder is a powerful and user-friendly navigation solution, enabling organizations to create custom navigation maps to facilitate accessibility for individuals with disabilities. Whether indoor or outdoor, Pathfinder aims to simplify the wayfinding process by providing clear, step-by-step guidance through complex environments, such as hospitals, universities, or large corporate campuses.",
  "main": "app.ts",
  "scripts": {
    "start": "tsc && node dist/app.js",
    "dev": "nodemon --exec ts-node app.ts",
    "build": "tsc",
    "migration:create": "sequelize migration:create",
    "migration:run": "sequelize db:migrate",
    "migration:undo": "sequelize db:migrate:undo",
    "migration:undo:all": "sequelize db:migrate:undo:all",
    "seed:create": "sequelize seed:generate",
    "seed:run": "sequelize db:seed:all",
    "seed:undo": "sequelize db:seed:undo",
    "seed:undo:all": "sequelize db:seed:undo:all",
    "db:reset": "sequelize db:migrate:undo:all && sequelize db:migrate",
    "db:reset:hard": "sequelize db:migrate:undo:all && sequelize db:migrate:undo:all && sequelize db:migrate",
    "sequelize:init": "sequelize init",
    "generate:models": "node ./db/generate-models.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prieston/pathfinder.git"
  },
  "keywords": [
    "navigation",
    "accessibility",
    "wayfinding",
    "maps",
    "indoor",
    "navigation"
  ],
  "author": "Theofilos Papadopoulos",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/prieston/pathfinder/issues"
  },
  "homepage": "https://github.com/prieston/pathfinder#readme",
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.1",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.1.13",
    "sequelize": "^6.32.1",
    "sequelize-cli": "^6.6.1",
    "sequelize-typescript": "^2.1.5",
    "sequelize-typescript-generator": "^10.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/node": "^20.4.5",
    "@types/passport": "^1.0.12",
    "@types/passport-google-oauth20": "^2.0.11",
    "dotenv": "^16.3.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
